# Master Environment Configuration Template
# Values should correspond to actual deployment parameters (e.g. from Secrets/ConfigMaps)

# Database Configuration
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=db
DB_PORT=5432
DB_NAME=your_db_name

# Mongo Configuration
MONGO_USER=your_mongo_user
MONGO_PASSWORD=your_mongo_password
MONGO_HOST=events-db
MONGO_PORT=27017

# RabbitMQ Configuration
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672

# Redis Configuration
REDIS_HOST=notification-redis
REDIS_PORT=6379

# Internal Service Hostnames
BOOKING_SERVICE_HOST=booking-service
BOOKING_SERVICE_PORT=8003
EVENTS_SERVICE_HOST=events-service
EVENTS_SERVICE_PORT=8002
NOTIFICATION_SERVICE_HOST=notification-service
NOTIFICATION_SERVICE_PORT=8006
TICKET_SERVICE_HOST=ticket-service
TICKET_SERVICE_PORT=8005

# External APIs
GEMINI_API_KEY=your_gemini_api_key_here
